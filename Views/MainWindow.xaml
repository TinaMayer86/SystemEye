<Window x:Class="SystemEye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:SystemEye"
        mc:Ignorable="d"
        Title="SystemEye" Height="700" Width="1100"
        WindowStyle="None" 
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="25" />
    </WindowChrome.WindowChrome>
    <materialDesign:DialogHost>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <materialDesign:ColorZone Mode="PrimaryMid"
                                      Padding="8"
                                      materialDesign:ElevationAssist.Elevation="Dp4"
                                      MouseDown="TitleBar_MouseDown">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White"
                                Click="MinimizeButton_Click">
                            <materialDesign:PackIcon Kind="WindowMinimize" />
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White"
                                Click="MaximizeButton_Click">
                            <materialDesign:PackIcon x:Name="MaximizeIcon"
                                                     Kind="WindowMaximize" />
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White"
                                Click="CloseButton_Click">
                            <materialDesign:PackIcon Kind="Close" />
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="MonitorEye"
                                                 Width="24" Height="24"
                                                 Margin="8,0,8,0"
                                                 Foreground="White"/>
                        <TextBlock Text="SystemEye Monitor"
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center" 
                                   Foreground="White"/>
                    </StackPanel>
                </DockPanel>
            </materialDesign:ColorZone>
            <TabControl Grid.Row="1" 
                        Style="{StaticResource MaterialDesignTabControl}"
                        materialDesign:ColorZoneAssist.Mode="PrimaryMid">
                <TabItem Header="1. Informationen" 
                         Width="auto">
                    <Grid Margin="20">
                        <materialDesign:Card Padding="16"
                             materialDesign:ElevationAssist.Elevation="Dp1"
                             UniformCornerRadius="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="Hardware-Übersicht"
                                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                           Margin="0,0,0,16"/>
                                <ScrollViewer Grid.Row="1" 
                                              VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ListBox ItemsSource="{Binding SystemInformation}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             PreviewMouseWheel="ListBox_PreviewMouseWheel">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,4">
                                                    <materialDesign:PackIcon Kind="ChevronRight"
                                                                             Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding}"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="16"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>
                <TabItem Header="2. Live" 
                         Width="auto">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <WrapPanel x:Name="ChartsWrapPanel"
                                       Orientation="Horizontal"
                                       HorizontalAlignment="Center"
                                       Margin="10"/>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Header="Historie">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <materialDesign:Chip Content="{Binding NextUpdateText}"
                                                 ToolTip="Zeit bis zur nächsten Datenbank-Speicherung"
                                                 Foreground="{DynamicResource MaterialDesignBody}">
                                <materialDesign:Chip.Icon> 
                                    <materialDesign:PackIcon Kind="Clock"
                                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </materialDesign:Chip.Icon>
                            </materialDesign:Chip>
                        </StackPanel>
                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    Margin="0,0,0,12">
                            <TextBlock Text="Historie blättern:" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,12,0" 
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                            <Button Command="{Binding PreviousHistoryPageCommand}" 
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    ToolTip="Neuere Daten laden"
                                    Width="40" Height="40"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    materialDesign:ButtonAssist.CornerRadius="20">
                                <materialDesign:PackIcon Kind="ChevronLeft" 
                                                         Width="24" 
                                                         Height="24" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                            </Button>

                            <Button Command="{Binding NextHistoryPageCommand}" 
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    ToolTip="Ältere Daten laden"
                                    Width="40" Height="40"
                                    Padding="0"
                                    materialDesign:ButtonAssist.CornerRadius="20">
                                <materialDesign:PackIcon Kind="ChevronRight" 
                                                         Width="24" 
                                                         Height="24" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                            </Button>
                        </StackPanel>
                        <materialDesign:Card Grid.Row="2" 
                                             UniformCornerRadius="15" 
                                             Padding="8" 
                                             materialDesign:ElevationAssist.Elevation="Dp4">
                            <DataGrid ItemsSource="{Binding DatabaseRecords}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      CanUserAddRows="False"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeitpunkt" Binding="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Hardware" Binding="{Binding HardwareType}" Width="Auto"/>
                                    <DataGridTextColumn Header="Sensor" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Min" Binding="{Binding MinValue, StringFormat='\{0:F1\}'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Max" Binding="{Binding MaxValue, StringFormat='\{0:F1\}'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Schnitt" Binding="{Binding AvgValue, StringFormat='\{0:F1\}'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Einheit" Binding="{Binding Format}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>
                <TabItem Header="4. Einstellungen">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="380" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:Card Grid.Column="0" 
                                             Padding="20" 
                                             Margin="0,0,12,0"
                                             materialDesign:ElevationAssist.Elevation="Dp1"
                                             UniformCornerRadius="16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                    <TextBlock Text="Sichtbare Sensoren"
                                               Style="{StaticResource MaterialDesignHeadline5TextBlock}" />
                                    <TextBlock Text="Wählen Sie aus, welche Hardware-Sensoren im Dashboard und in der Historie erfasst werden sollen."
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Opacity="0.6" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Bottom"
                                        Command="{Binding SaveSensorConfigCommand}"
                                        Content="Konfiguration Speichern"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Margin="0,16,0,0"
                                        HorizontalAlignment="Right"
                                        materialDesign:ButtonAssist.CornerRadius="10"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AvailableSensors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled}"
                                                          Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}"
                                                          Margin="0,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="Bold"
                                                                   Width="200"/>
                                                        <TextBlock Text="{Binding HardwareType}"
                                                                   Opacity="0.5"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </materialDesign:Card>

                        <StackPanel Grid.Column="1">
                            <materialDesign:Card Padding="16"
                                                 Margin="0,0,0,16"
                                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                                 UniformCornerRadius="16">
                                <StackPanel>
                                    <TextBlock Text="Darstellung"
                                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                               Margin="0,0,0,10"/>
                                    <DockPanel>
                                        <TextBlock Text="Dunkles Design"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ThemeToggleButton" 
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" 
                                                      DockPanel.Dock="Right"
                                                      HorizontalAlignment="Right"
                                                      IsChecked="True"
                                                      Click="ThemeToggleButton_Click"/>
                                    </DockPanel>
                                </StackPanel>
                            </materialDesign:Card>
                            <materialDesign:Card Padding="20" 
                                                 Margin="0,0,0,16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2"
                                                 UniformCornerRadius="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <materialDesign:PackIcon Kind="FileExport"
                                                                 Width="24"
                                                                 Height="24"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Daten Export"
                                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                                   Margin="12,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="Speichert die Durchschnitts-, Minimum- und Maximumwerte der letzten Stunde als Textdatei auf Ihrem Desktop."
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Margin="0,0,0,20" />
                                    <Button Command="{Binding ExportLogCommand}" 
                                            Content="Jetzt Exportieren" 
                                            Margin="0,10,0,0" 
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="10"
                                            FontWeight="Regular"
                                            FontSize="14"
                                            Foreground="{DynamicResource MaterialDesignBody}"
                                            Typography.Capitals="Normal"/>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Padding="20" 
                                                 Margin="0,0,0,16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2"
                                                 UniformCornerRadius="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" 
                                                Margin="0,0,0,12">
                                        <materialDesign:PackIcon Kind="DatabaseAlert" 
                                                                 Foreground="{DynamicResource MaterialDesignBody}" 
                                                                 Width="24" Height="24" 
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Datenbank zurücksetzen"
                                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                                   Margin="12,0,0,0"
                                                   Foreground="{DynamicResource MaterialDesignBody}" />
                                    </StackPanel>
                                    <TextBlock Text="Alle aufgezeichneten Statistiken werden unwiderruflich gelöscht. Dies ist nützlich, wenn Sie die Hardware gewechselt haben."
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Margin="0,0,0,20" />

                                    <Button Command="{Binding ResetDatabaseCommand}"
                                            Content="ALLES LÖSCHEN"
                                            Margin="0,10,0,0" 
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="10"
                                            FontWeight="Regular"
                                            FontSize="14"
                                            Foreground="{DynamicResource MaterialDesignBody}"
                                            Typography.Capitals="Normal"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </materialDesign:DialogHost>
</Window>
